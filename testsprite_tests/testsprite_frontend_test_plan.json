[
  {
    "id": "TC001",
    "title": "Deep-linking to /profile shows Not Found behavior (known SPA limitation)",
    "description": "Verifies that direct navigation to a deep link like /profile results in a Not Found/404 state instead of the SPA screen.",
    "category": "App Navigation (SPA)",
    "priority": "Medium",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to \"http://localhost:3000/profile\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"404\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Not Found\" is visible"
      }
    ]
  },
  {
    "id": "TC002",
    "title": "Unlock admin dashboard with correct master password",
    "description": "Verifies that a user can unlock the Admin Dashboard by entering the correct master password and submitting the gate form.",
    "category": "Admin Dashboard Gateway",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to \"http://localhost:3000/admin\""
      },
      {
        "type": "assertion",
        "description": "Verify element \"SplashScreen\" is visible"
      },
      {
        "type": "action",
        "description": "Wait for 1 second"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Accedir\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"mistic_master_audit\" into the password field"
      },
      {
        "type": "action",
        "description": "Click \"Accedir\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Admin Dashboard\" is visible"
      }
    ]
  },
