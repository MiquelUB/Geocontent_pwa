    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to \"http://localhost:3000/\""
      },
      {
        "type": "action",
        "description": "Wait for the SplashScreen to finish (~800ms)"
      },
      {
        "type": "action",
        "description": "Click \"Perfil\" in the Bottom Navigation"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Nivell\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Segells\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify the stamps grid is visible"
      },
      {
        "type": "assertion",
        "description": "Verify at least one unlocked stamp item is visible in the stamps grid"
      }
    ]
  },
